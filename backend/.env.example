# Copy this file to .env and fill in your actual values
# Never commit .env to git

# AWS RDS PostgreSQL connection string
# Format: postgresql://username:password@endpoint:5432/dbname
DATABASE_URL=postgresql://todo_app_user:YOUR_PASSWORD@YOUR_RDS_ENDPOINT:5432/gamified_todo_db

# JWT Secret Key — generate a strong random string, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_long_random_secret_key

# Get your free Groq key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: CORS origins (comma-separated, defaults to * if not set)
# ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app